# ParseHub Dashboard - Environment Configuration Template
# Copy this file to backend/src/config/.env and fill in your values

# ---------- ParseHub API Configuration ----------
PARSEHUB_API_KEY=your_api_key_here
PARSEHUB_BASE_URL=https://www.parsehub.com/api/v2

# ---------- Frontend Configuration ----------
NEXT_PUBLIC_API_URL=http://localhost:5000

# ---------- Snowflake Configuration ----------
SNOWFLAKE_ACCOUNT=ACCOUNT_ID
SNOWFLAKE_USER=username
SNOWFLAKE_PASSWORD=password
SNOWFLAKE_WAREHOUSE=WAREHOUSE_NAME
SNOWFLAKE_DATABASE=DATABASE_NAME
SNOWFLAKE_SCHEMA=SCHEMA_NAME

# ---------- Database Configuration ----------
# SQLite (for local development)
DATABASE_PATH=parsehub.db

# PostgreSQL (for production)
DATABASE_URL=postgresql://user:password@host:5432/database

# ---------- Server Configuration ----------
PORT=5000
HOST=0.0.0.0
DEBUG=False
ENVIRONMENT=production

# ---------- Flask Configuration ----------
FLASK_ENV=production
FLASK_APP=src.api.api_server
SECRET_KEY=your-secret-key-here

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=logs/parsehub.log

# ---------- Optional: External Services ----------
# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Slack (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
